\">\n              {limit}\n            </span>\n            <span className=\"text-2xl font-headline font-bold text-primary\">MUSD</span>\n          </div>\n          <div className=\"text-[10px] text-gray-400 font-bold uppercase tracking-widest\">\n            Spending Limit Per Market\n          </div>\n        </div>\n\n        {/* Progress Bar for Mandate Usage */}\n        <div className=\"space-y-2\">\n          <div className=\"flex justify-between items-center text-[10px] font-bold uppercase tracking-widest\">\n            <span className=\"text-gray-400\">Used this period</span>\n            <span className=\"text-black\">{used} MUSD</span>\n          </div>\n          <div className=\"h-2 w-full bg-gray-100 rounded-full overflow-hidden\">\n            <div \n              className=\"h-full bg-primary transition-all duration-1000\" \n              style={{ width: `${(parseFloat(used) / parseFloat(limit)) * 100}%` }}\n            />\n          </div>\n        </div>\n      </div>\n\n      <div className=\"pt-2 border-t border-black/[0.03] mt-2\">\n        <p className=\"text-[10px] text-gray-400 leading-relaxed italic\">\n          \"Mezo Passport ensures every stake is gasless within your mandate limit.\"\n        </p>\n      </div>\n    </div>\n  );\n};\n\nexport default MandateCard;\n","usedDeprecatedRules":[]},{"filePath":"/Users/amc/Workspace/hackathon/mezo/frontend/components/dashboard/ResolverQueue.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Link' is defined but never used.","line":4,"column":8,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Link"},"fix":{"range":[42,72],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport React from \"react\";\nimport Link from \"next/link\";\n\ninterface PendingMarket {\n  id: string;\n  question: string;\n  groupName: string;\n  totalMUSD: string;\n  deadline: string;\n  color: string;\n}\n\nconst MOCK_PENDING: PendingMarket[] = [\n  {\n    id: \"m1\",\n    question: \"Will BTC close above $120K this month?\",\n    groupName: \"Mezo Alpha Chat\",\n    totalMUSD: \"4,250.00\",\n    deadline: \"2h ago\",\n    color: \"bg-primary\",\n  },\n  {\n    id: \"m2\",\n    question: \"Will the MUSD peg hold through the halving?\",\n    groupName: \"Jakarta Prediction DAO\",\n    totalMUSD: \"1,850.50\",\n    deadline: \"5h ago\",\n    color: \"bg-accent-purple\",\n  },\n];\n\nconst ResolverQueue = () => {\n  if (MOCK_PENDING.length === 0) return null;\n\n  return (\n    <div className=\"bg-white rounded-3xl p-8 flex flex-col h-full shadow-sm border border-black/[0.05] relative overflow-hidden group\">\n      {/* Background Accent */}\n      <div className=\"absolute top-0 right-0 w-32 h-32 bg-orange-500/5 blur-3xl -z-10 group-hover:bg-orange-500/10 transition-colors duration-700\" />\n      \n      <div className=\"flex justify-between items-center mb-8\">\n        <div>\n          <h3 className=\"text-[10px] font-bold uppercase tracking-widest text-orange-500\">\n            Action Required: Resolver Queue\n          </h3>\n          <p className=\"text-[10px] text-gray-400 font-medium mt-0.5 uppercase tracking-wider\">\n            Markets awaiting your trusted resolution\n          </p>\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <span className=\"w-2 h-2 rounded-full bg-orange-500 animate-pulse\" />\n          <span className=\"text-[9px] font-bold uppercase tracking-widest text-orange-500\">{MOCK_PENDING.length} Markets</span>\n        </div>\n      </div>\n\n      <div className=\"space-y-4 flex-1\">\n        {MOCK_PENDING.map((market) => (\n          <div \n            key={market.id} \n            className=\"p-5 rounded-2xl bg-gray-50 border border-black/[0.03] flex flex-col gap-4 hover:border-orange-500 transition-all hover:bg-white active:scale-95 cursor-pointer group/card\"\n          >\n            <div className=\"flex justify-between items-start\">\n              <div className=\"space-y-1\">\n                <p className=\"text-[9px] font-bold uppercase tracking-widest text-gray-400\">\n                  {market.groupName}\n                </p>\n                <h4 className=\"font-headline font-bold text-sm text-black leading-tight\">\n                  {market.question}\n                </h4>\n              </div>\n              <div className=\"text-[9px] font-bold px-2 py-1 bg-white border border-black/[0.05] rounded-full text-orange-500 tabular-nums\">\n                {market.deadline}\n              </div>\n            </div>\n\n            <div className=\"flex items-center justify-between\">\n              <div className=\"flex flex-col gap-0.5\">\n                <span className=\"text-[9px] font-bold uppercase tracking-widest text-gray-400\">Total Pool</span>\n                <span className=\"text-xs font-bold text-black tabular-nums\">{market.totalMUSD} MUSD</span>\n              </div>\n              <button className=\"px-4 py-2 bg-black text-white text-[10px] font-bold uppercase tracking-widest rounded-full hover:scale-105 active:scale-95 transition-all shadow-md\">\n                Resolve Now\n              </button>\n            </div>\n          </div>\n        ))}\n      </div>\n\n      <div className=\"mt-8 pt-4 border-t border-black/[0.03]\">\n        <div className=\"flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-gray-400\">\n          <span className=\"material-symbols-outlined text-sm\">security</span>\n          <span>Community Trusted Arbitration</span>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default ResolverQueue;\n","usedDeprecatedRules":[]},{"filePath":"/Users/amc/Workspace/hackathon/mezo/frontend/components/dashboard/Sidebar.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/amc/Workspace/hackathon/mezo/frontend/components/dashboard/StatsCard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/amc/Workspace/hackathon/mezo/frontend/components/dashboard/Timeline.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'setStakes' is assigned a value but never used.","line":41,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":41,"endColumn":27},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'idx' is assigned a value but never used.","line":44,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":44,"endColumn":12}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport React, { useEffect, useState } from \"react\";\n\n// ─── Types ────────────────────────────────────────────────────────────────────\n\ntype StakeDirection = \"YES\" | \"NO\" | \"ZERO_RISK\";\n\ninterface StakeEvent {\n  id: string;\n  time: string;       \n  direction: StakeDirection;\n  amount: number;     \n  walletInitial: string;\n  walletColor: string;\n  marketLabel: string;\n}\n\n// ─── Mock live stake feed ───\n\nconst MOCK_STAKES: StakeEvent[] = [\n  { id: \"s1\", time: \"16:52\", direction: \"YES\",       amount: 50,  walletInitial: \"R\", walletColor: \"#3b82f6\", marketLabel: \"BTC > $120K?\" },\n  { id: \"s2\", time: \"16:48\", direction: \"NO\",        amount: 25,  walletInitial: \"M\", walletColor: \"#f97316\", marketLabel: \"ETH Flip?\" },\n  { id: \"s3\", time: \"16:41\", direction: \"YES\",       amount: 100, walletInitial: \"A\", walletColor: \"#3b82f6\", marketLabel: \"Halving rally?\" },\n  { id: \"s4\", time: \"16:35\", direction: \"ZERO_RISK\", amount: 8,   walletInitial: \"K\", walletColor: \"#22c55e\", marketLabel: \"MUSD peg?\" },\n  { id: \"s5\", time: \"16:22\", direction: \"NO\",        amount: 30,  walletInitial: \"T\", walletColor: \"#f97316\", marketLabel: \"BTC > $120K?\" },\n  { id: \"s6\", time: \"16:09\", direction: \"YES\",       amount: 75,  walletInitial: \"D\", walletColor: \"#3b82f6\", marketLabel: \"Mezo TVL?\" },\n];\n\nconst MAX_STAKE = Math.max(...MOCK_STAKES.map((s) => s.amount));\n\nconst directionMeta: Record<StakeDirection, { color: string; bg: string; icon: string }> = {\n  YES:       { color: \"#3b82f6\", bg: \"bg-primary\",        icon: \"check_circle\" },\n  NO:        { color: \"#f97316\", bg: \"bg-secondary\",      icon: \"cancel\" },\n  ZERO_RISK: { color: \"#22c55e\", bg: \"bg-accent-green\",   icon: \"bolt\" },\n};\n\n// ─── Live Stake Feed ──────────────────────────────────────────────────────────\n\nconst LiveStakeFeed = () => {\n  const [stakes, setStakes] = useState<StakeEvent[]>(MOCK_STAKES);\n\n  useEffect(() => {\n    let idx = 0;\n    const timer = setInterval(() => {\n      idx++;\n    }, 12000);\n    return () => clearInterval(timer);\n  }, []);\n\n  return (\n    <div className=\"col-span-12 lg:col-span-12 xl:col-span-5 bg-white rounded-3xl p-8 flex flex-col h-full min-h-[584px] shadow-sm border border-black/[0.05]\">\n      {/* Header */}\n      <div className=\"flex justify-between items-center mb-10\">\n        <div>\n          <h3 className=\"text-[10px] font-bold uppercase tracking-widest text-gray-400\">\n            Live Stake Feed\n          </h3>\n          <p className=\"text-[10px] text-gray-300 font-medium mt-0.5 uppercase tracking-wider\">\n            Real-time market activity\n          </p>\n        </div>\n        <div className=\"flex gap-3 items-center\">\n          <div title=\"YES stakes\" className=\"opacity-50 hover:opacity-100 transition-opacity cursor-help\">\n            <span className=\"material-symbols-outlined text-sm text-primary\" style={{ fontVariationSettings: \"'wght' 500\" }}>check_circle</span>\n          </div>\n          <div title=\"NO stakes\" className=\"opacity-50 hover:opacity-100 transition-opacity cursor-help\">\n            <span className=\"material-symbols-outlined text-sm text-secondary\" style={{ fontVariationSettings: \"'wght' 500\" }}>cancel</span>\n          </div>\n          <div title=\"Zero Risk stakes\" className=\"opacity-50 hover:opacity-100 transition-opacity cursor-help\">\n            <span className=\"material-symbols-outlined text-sm text-accent-green\" style={{ fontVariationSettings: \"'wght' 500\" }}>bolt</span>\n          </div>\n          <div className=\"flex items-center gap-1.5 ml-1\">\n            <span className=\"w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse\" />\n            <span className=\"text-[9px] font-bold uppercase tracking-widest text-gray-300\">LIVE</span>\n          </div>\n        </div>\n      </div>\n\n      {/* Stakes timeline */}\n      <div className=\"flex-1 relative border-l border-gray-100 ml-12 space-y-6\">\n        {stakes.map((stake) => {\n          const meta = directionMeta[stake.direction];\n          const barWidthPct = Math.round((stake.amount / MAX_STAKE) * 100);\n          const isZeroRisk = stake.direction === \"ZERO_RISK\";\n\n          return (\n            <div key={stake.id} className=\"relative py-1.5\">\n              <span className=\"absolute -left-[4.5rem] top-1/2 -translate-y-1/2 text-[10px] font-bold text-gray-300 tabular-nums\">\n                {stake.time}\n              </span>\n\n              <div style={{ width: `${Math.max(barWidthPct, 35)}%` }}>\n                <div\n                  className=\"w-full h-8 rounded-full flex items-center justify-between px-2 transition-all hover:scale-[1.02] cursor-pointer\"\n                  style={{ \n                    background: isZeroRisk ? \"rgba(34, 197, 94, 0.1)\" : meta.color,\n                    border: isZeroRisk ? \"1px solid rgba(34, 197, 94, 0.2)\" : \"none\"\n                  }}\n                >\n                  <div\n                    className=\"w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 text-[10px] font-black\"\n                    style={{\n                      background: isZeroRisk ? \"#22c55e\" : \"rgba(0,0,0,0.1)\",\n                      color: isZeroRisk ? \"#fff\" : \"rgba(255,255,255,0.9)\",\n                    }}\n                  >\n                    {stake.walletInitial}\n                  </div>\n\n                  <div className=\"flex items-center gap-1\">\n                    <span\n                      className=\"text-[10px] font-bold\"\n                      style={{ color: isZeroRisk ? \"#22c55e\" : \"#fff\" }}\n                    >\n                      {stake.amount} MUSD\n                    </span>\n                    <span\n                      className=\"material-symbols-outlined text-[12px]\"\n                      style={{\n                        fontVariationSettings: \"'wght' 600\",\n                        color: isZeroRisk ? \"#22c55e\" : \"#fff\",\n                      }}\n                    >\n                      {meta.icon}\n                    </span>\n                  </div>\n                </div>\n\n                <div className=\"text-[9px] text-gray-400 font-medium mt-0.5 pl-1 truncate\">\n                  {stake.marketLabel}\n                </div>\n              </div>\n            </div>\n          );\n        })}\n      </div>\n\n      {/* Footer legend */}\n      <div className=\"mt-6 pt-4 flex justify-between items-center text-[10px] font-bold uppercase tracking-widest text-gray-400 border-t border-gray-50\">\n        <div className=\"flex gap-4\">\n          <span className=\"flex items-center gap-1.5\">\n            <span className=\"w-2 h-2 rounded-full bg-primary inline-block\" />\n            YES\n          </span>\n          <span className=\"flex items-center gap-1.5\">\n            <span className=\"w-2 h-2 rounded-full bg-secondary inline-block\" />\n            NO\n          </span>\n          <span className=\"flex items-center gap-1.5\">\n            <span className=\"w-2 h-2 rounded-full bg-accent-green inline-block\" />\n            Zero Risk\n          </span>\n        </div>\n        <span className=\"text-gray-300\">Last 6 events</span>\n      </div>\n    </div>\n  );\n};\n\nexport default LiveStakeFeed;\n","usedDeprecatedRules":[]},{"filePath":"/Users/amc/Workspace/hackathon/mezo/frontend/components/dashboard/TopBar.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'YieldCounter' is defined but never used.","line":9,"column":8,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":20,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"YieldCounter"},"fix":{"range":[297,361],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'getGroup'. Either include it or remove the dependency array.","line":36,"column":6,"nodeType":"ArrayExpression","endLine":36,"endColumn":33,"suggestions":[{"desc":"Update the dependencies array to be: [groupId, getGroup.execute, getGroup]","fix":{"range":[1220,1247],"text":"[groupId, getGroup.execute, getGroup]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has missing dependencies: 'getAccruedYield', 'getMandate', 'getNotifications', and 'getProfile'. Either include them or remove the dependency array.","line":46,"column":6,"nodeType":"ArrayExpression","endLine":46,"endColumn":121,"suggestions":[{"desc":"Update the dependencies array to be: [isAuthenticated, token, getAccruedYield.execute, getMandate.execute, getNotifications.execute, getProfile.execute, getAccruedYield